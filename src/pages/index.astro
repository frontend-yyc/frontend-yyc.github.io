---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";

const metadata = {
  title: `${siteConfig.name} — Web Developers Meetup in Calgary`,
  description:
    "A recurring community meetup for web developers in Calgary. Join us for talks, demos, and networking.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Hero
    title={`<span class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Frontend and Beyond</span><br class="hidden md:block" /> Calgary Web Developers`}
    tagline="Meetup Community"
    description="A recurring community gathering for web developers in Calgary. Connect with fellow developers, learn from talks and demos, and expand your network."
    actions={[
      {
        text: "View Events",
        href: "/events",
        variant: "primary",
        icon: "lucide:calendar",
      },
      {
        text: "Get in Touch",
        href: "/contact",
        variant: "secondary",
        icon: "lucide:mail",
        ariaLabel: "Contact us about the meetup",
      },
    ]}
  />
  <Features
    tagline="Community"
    title="Why Join Us?"
    subtitle="Everything you need for a great meetup experience."
    features={[
      {
        title: "Community",
        description:
          "Connect with fellow web developers, share experiences, and build relationships.",
        icon: "lucide:users",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Networking",
        description:
          "Meet professionals, exchange ideas, and collaborate on projects.",
        icon: "lucide:network",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Talks & Demos",
        description:
          "Learn from expert talks, see live demos, and stay updated with latest web technologies.",
        icon: "lucide:presentation",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
  />
</BaseLayout>
