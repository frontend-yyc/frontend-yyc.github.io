---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Schema from "@/components/seo/Schema.astro";
import { Icon } from "astro-icon/components";

import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const blog = await getCollection("blog");
  return blog.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const {
  title,
  description,
  pubDate,
  author,
  image,
  eventbrite,
  presenters,
  slideDeck,
} = post.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const metadata = {
  title: title,
  description: description,
  ogImage: image,
};
---

<BaseLayout metadata={metadata}>
  <Schema
    type="BlogPosting"
    data={{
      title,
      description,
      image,
      pubDate,
      author,
      url: Astro.url.href,
    }}
  />
  <section class="relative px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="relative mx-auto max-w-3xl">
      <div class="reveal mb-10 text-center">
        <p class="text-sm font-semibold tracking-wide text-primary uppercase">
          {formattedDate} • {author}
        </p>
        <h1
          class="font-heading mt-2 text-3xl font-bold leading-tight tracking-tighter text-foreground sm:text-4xl md:text-5xl"
        >
          {title}
        </h1>
      </div>

      {
        presenters && presenters.length > 0 && (
          <div class="reveal mb-8 rounded-xl border border-border bg-card p-8 text-left">
            <p class="mb-4 text-sm font-semibold tracking-wide text-primary uppercase">
              Presented by
            </p>
            <div class="space-y-4">
              {presenters.map((presenter) => (
                <div class="flex flex-col">
                  <div>
                    {presenter.page ? (
                      <a
                        href={presenter.page}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-lg font-semibold text-primary hover:underline"
                      >
                        {presenter.name}
                      </a>
                    ) : (
                      <p class="text-lg font-semibold text-foreground">
                        {presenter.name}
                      </p>
                    )}
                  </div>
                  {presenter.title && (
                    <p class="text-sm text-muted-foreground">
                      {presenter.title}
                    </p>
                  )}
                </div>
              ))}
            </div>
            {slideDeck && (
              <div class="mt-6 pt-6 border-t border-border">
                <a
                  href={slideDeck}
                  download
                  class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-primary/80 transition-colors"
                >
                  <Icon name="lucide:download" class="h-4 w-4" />
                  Download slides
                </a>
              </div>
            )}
          </div>
        )
      }

      {
        image && (
          <div class="reveal relative mb-8 h-96 w-full overflow-hidden rounded-xl shadow-lg">
            <img src={image} alt={title} class="h-full w-full object-cover" />
          </div>
        )
      }

      <div
        class="reveal prose prose-lg dark:prose-invert mx-auto prose-headings:text-foreground prose-a:text-primary hover:prose-a:underline prose-p:text-muted-foreground prose-strong:text-foreground prose-li:text-muted-foreground prose-code:text-primary"
      >
        <Content />
      </div>

      {
        eventbrite && (
          <div class="reveal mt-12 rounded-xl border border-border bg-card p-8 text-center">
            <p class="mb-4 text-lg font-semibold text-foreground">
              Interested in attending this event?
            </p>
            <a
              href={eventbrite}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-primary text-primary-foreground px-8 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors"
            >
              Register on Eventbrite →
            </a>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
