---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Content from "@/components/widgets/Content.astro";

const metadata = {
  title: "Contact",
  description: "Get in touch with the Frontend and Beyond meetup organizers.",
};

const description = [
  "Reach out to us about upcoming events, sponsorships, or to become a speaker at Frontend and Beyond.",
];
---

<BaseLayout {metadata}>
  <Content tagline="Contact" title="Get in Touch" description={description} />
  <div
    class="reveal mx-auto max-w-xl bg-card border border-border rounded-3xl p-8 shadow-sm mb-12 md:mb-16 text-center"
  >
    <p class="text-muted-foreground mb-6">Send us an email:</p>
    <a
      href="mailto:frontend.yyc@gmail.com"
      class="inline-block px-8 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors"
    >
      frontend.yyc@gmail.com
    </a>
  </div>
</BaseLayout>
